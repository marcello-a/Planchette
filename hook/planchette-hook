#!/bin/sh
# planchette-hook — forwards a Claude Code hook event to the Planchette app.
#
# Claude Code invokes this with the event JSON on stdin (fields like
# hook_event_name, session_id, transcript_path, cwd, message). We wrap it
# with the terminal identity from $PLANCHETTE_SESSION (injected into every
# Planchette terminal, inherited by claude and thus by this hook) and send
# it to the app's unix socket. Spike version — production will be a static
# binary with proper JSON handling.
#
# Always exit 0: a missing/busy app must never block Claude.

SOCKET="${PLANCHETTE_SOCKET:-/tmp/planchette-spike.sock}"
[ -S "$SOCKET" ] || exit 0

payload=$(cat)
[ -n "$payload" ] || payload='{}'

printf '{"planchette_session":"%s","event":%s}' "${PLANCHETTE_SESSION:-}" "$payload" \
    | nc -U "$SOCKET" >/dev/null 2>&1 || true

exit 0
